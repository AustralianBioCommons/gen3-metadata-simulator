# Copy to .env and fill in the three LLM settings below.
# .env is gitignored. It holds the PATH to your key file, never the key itself.

# LLM vendor: anthropic or openai
LLM_PROVIDER=anthropic

# Model id — e.g. claude-haiku-4-5 (anthropic) or gpt-4o-mini (openai)
LLM_MODEL=claude-haiku-4-5

# Path to a file containing your API key (the key lives in this file, not here).
# Use a key that matches LLM_PROVIDER above. Keep the file outside the repo, and
# use an ABSOLUTE path (a relative path is resolved against the working dir).
#
# Optional: if you omit LLM_API_KEY_FILE, the vendor's standard environment
# variable is used instead — OPENAI_API_KEY (openai) or ANTHROPIC_API_KEY
# (anthropic). Handy when the tool is pip-installed and you already have one set.
LLM_API_KEY_FILE=/path/to/your/api_key
